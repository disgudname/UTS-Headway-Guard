          }\n                        }\n                    },\n                    \"default\": {\n                        \"description\": \"Error\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Error\"\n                                }\n                            }\n                        }\n                    }\n                },\n                \"security\": [\n                    {\n                        \"App_OAuth\": [\n                            \"announcement:write\"\n                        ]\n                    }\n                ]\n            }\n        },\n        \"/announcements/active\": {\n            \"get\": {\n                \"operationId\": \"GET-announcements-active\",\n                \"summary\": \"Retrieve active announcements\",\n                \"tags\": [\n                    \"Announcements\"\n                ],\n                \"description\": \"To receive announcements that are currently active at the location of a rider, supply `latitude` and `longitude` query string parameters.\",\n                \"parameters\": [\n                    {\n                        \"name\": \"latitude\",\n                        \"in\": \"query\",\n                        \"schema\": {\n                            \"type\": \"number\",\n                            \"nullable\": true\n                        }\n                    },\n                    {\n                        \"name\": \"longitude\",\n                        \"in\": \"query\",\n                        \"schema\": {\n                            \"type\": \"number\",\n                            \"nullable\": true\n                        }\n                    }\n                ],\n                \"responses\": {\n                    \"200\": {\n                        \"description\": \"\",\n            