          }\n                        }\n                    },\n                    \"default\": {\n                        \"description\": \"Error\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Error\"\n                                }\n                            }\n                        }\n                    }\n                },\n                \"security\": [\n                    {\n                        \"Authorization\": []\n                    }\n                ]\n            }\n        },\n        \"/connectedAccounts/gopass/paymentMethod\": {\n            \"post\": {\n                \"operationId\": \"POST-connectedAccounts-gopass-paymentMethod\",\n                \"summary\": \"Connect GoPass Tap Card\",\n                \"tags\": [\n                    \"Connected Accounts\"\n                ],\n                \"requestBody\": {\n                    \"content\": {\n                        \"application/json\": {\n                            \"schema\": {\n                                \"type\": \"object\",\n                                \"additionalProperties\": false,\n                                \"properties\": {\n                                    \"externalId\": {\n                                        \"type\": \"string\",\n                                        \"description\": \"GoPass tap card number identifier\"\n                                    },\n                                    \"userId\": {\n                                        \"type\": \"string\",\n                                        \"description\": \"Spare user identifier\",\n                                        \"format\": \"uuid\"\n                                    }\n                                },\n                                \"required\": [\n                              