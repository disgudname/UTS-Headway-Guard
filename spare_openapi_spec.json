                                             \"type\": \"string\"\n                                                },\n                                                \"polygon\": {\n                                                    \"$ref\": \"#/components/schemas/Polygon\"\n                                                }\n                                            },\n                                            \"required\": [\n                                                \"name\",\n                                                \"polygon\"\n                                            ]\n                                        }\n                                    },\n                                    \"status\": {\n                                        \"$ref\": \"#/components/schemas/AnnouncementStatus\"\n                                    },\n                                    \"title\": {\n                                        \"type\": \"string\",\n                                        \"description\": \"Short title for the announcement\"\n                                    },\n                                    \"details\": {\n                                        \"type\": \"string\"\n                                    },\n                                    \"openUrl\": {\n                                        \"type\": \"string\",\n                                        \"description\": \"Optional url to see more information on the announcement\",\n                                        \"nullable\": true\n                                    },\n                                    \"color\": {\n                                        \"type\": \"string\",\n                                        \"description\": \"Colors are accepted in HEX format\",\n                                        \"pattern\": \"^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$\"\n                                    },\n                                    \"icon\": {\n                                        \"$ref\": \"#/components/schemas/AnnouncementIcon\"\n                                    },\n                                    \"priority\": {\n                                        \"type\": \"integer\",\n                                        \"minimum\": 1,\n                                        \"maximum\": 10\n                                    },\n                                    \"isAcknowledgementRequired\": {\n                                        \"type\": \"boolean\"\n                                    }\n                                }\n                            }\n                        }\n                    }\n                },\n                \"responses\": {\n                    \"200\": {\n                        \"description\": \"\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Announcement\"\n                                }\n                            }\n                        }\n                    },\n                    \"default\": {\n                        \"description\": \"Error\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Error\"\n                                }\n                            }\n                        }\n                    }\n                },\n                \"security\": [\n                    {\n                        \"App_OAuth\": [\n                            \"announcement:write\"\n                        ]\n                    }\n                ]\n            }\n        },\n        \"/auth/email/reset/request\": {\n            \"post\": {\n                \"operationId\": \"AUTH-email-reset-request\",\n                \"summary\": \"Email / Request password reset\",\n                \"tags\": [\n                    \"Authentication\"\n                ],\n                \"requestBody\": {\n                    \"content\": {\n                        \"application/json\": {\n                            \"schema\": {\n                                \"type\": \"object\",\n                                \"additionalProperties\": false,\n                                \"properties\": {\n                                    \"email\": {\n                                        \"type\": \"string\"\n                                    }\n                                },\n                                \"required\": [\n                                    \"email\"\n                                ]\n                            }\n                        }\n                    }\n                },\n                \"responses\": {\n                    \"200\": {\n                        \"description\": \"\"\n                    },\n                    \"default\": {\n                        \"description\": \"Error\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Error\"\n                                }\n                            }\n                        }\n                    }\n                }\n            }\n        },\n        \"/auth/email/reset/verify\": {\n            \"post\": {\n                \"operationId\": \"AUTH-email-reset-verify\",\n                \"summary\": \"Email / Confirm password reset\",\n                \"tags\": [\n                    \"Authentication\"\n                ],\n                \"requestBody\": {\n                    \"content\": {\n                        \"application/json\": {\n                            \"schema\": {\n                                \"type\": \"object\",\n                                \"additionalProperties\": false,\n                                \"properties\": {\n                                    \"token\": {\n                                        \"type\": \"string\",\n                                        \"description\": \"Verification code that was sent to the email\"\n                                    },\n                                    \"password\": {\n                                        \"type\": \"string\",\n                                        \"maxLength\": 1024\n                                    }\n                                },\n                                \"required\": [\n                                    \"token\",\n                                    \"password\"\n                                ]\n                            }\n                        }\n                    }\n                },\n                \"responses\": {\n                    \"200\": {\n                        \"description\": \"\"\n                    },\n                    \"default\": {\n                        \"description\": \"Error\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Error\"\n                                }\n                            }\n                        }\n                    }\n                }\n            }\n        },\n        \"/auth/token\": {\n            \"post\": {\n                \"operationId\": \"AUTH-token\",\n                \"summary\": \"Token / Generate a new token for user\",\n                \"tags\": [\n                    \"Authentication\"\n                ],\n                \"description\": \"This endpoint is used to generate user authentication tokens. The token returned can then be sent to the client of the user and used to perform authenticated operations\",\n                \"requestBody\": {\n                    \"content\": {\n                        \"application/json\": {\n                            \"schema\": {\n                                \"type\": \"object\",\n                                \"additionalProperties\": false,\n                                \"properties\": {\n                                    \"userId\": {\n                                        \"type\": \"string\",\n                                        \"format\": \"uuid\"\n                                    },\n                                    \"organizationId\": {\n                                        \"type\": \"string\",\n                                        \"format\": \"uuid\"\n                                    },\n                                    \"scope\": {\n                                        \"$ref\": \"#/components/schemas/Scope\"\n                                    }\n                                },\n                                \"required\": [\n                                    \"scope\"\n                                ],\n                                \"example\": {\n                                    \"userId\": \"c8dbf6a7-8cf7-41f0-9c38-912a1d44100c\",\n                                    \"organizationId\": \"5c9894b5-1c26-44d8-9ed9-ee526ffd5c46\",\n                                    \"scope\": \"full\"\n                                }\n                            }\n                        }\n                    }\n                },\n                \"responses\": {\n                    \"201\": {\n                        \"description\": \"Created\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Token\"\n                                },\n                                \"examples\": {\n                                    \"response\": {\n                                        \"value\": {\n                                            \"token\": \"hcHBsaWNhdGlvbnMvMWg3MlBGV29HeEhLaHlzS2pZSWtpciIsImlhdCI6MTQxNDk5NDAxNiwiZXhwIjoxNDE0OT\"\n                                        }\n                                    }\n                                }\n                            }\n                        }\n                    },\n                    \"default\": {\n                        \"description\": \"Error\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Error\"\n                                }\n                            }\n                        }\n                    }\n                },\n                \"security\": [\n                    {\n                        \"Authorization\": []\n                    }\n                ]\n            }\n        },\n        \"/charges\": {\n            \"get\": {\n                \"operationId\": \"LIST-charges\",\n                \"summary\": \"List all charges\",\n                \"tags\": [\n                    \"Charges\"\n                ],\n                \"parameters\": [\n                    {\n                        \"$ref\": \"#/components/parameters/LimitHigh\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/SkipHigh\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/FromCreatedAt\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/ToCreatedAt\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/OrderBy\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/OrderDirection\"\n                    },\n                    {\n                        \"name\": \"status\",\n                        \"in\": \"query\",\n                        \"schema\": {\n                            \"$ref\": \"#/components/schemas/ChargeStatus\"\n                        }\n                    },\n                    {\n                        \"name\": \"dispatchStatus\",\n                        \"in\": \"query\",\n                        \"schema\": {\n                            \"$ref\": \"#/components/schemas/RequestDispatchStatus\"\n                        }\n                    },\n                    {\n                        \"name\": \"requestId\",\n                        \"in\": \"query\",\n                        \"description\": \"Identifier of the request. If set, only charges associated with the request will be returned\",\n                        \"schema\": {\n                            \"type\": \"string\",\n                            \"format\": \"uuid\"\n                        }\n                    },\n                    {\n                        \"name\": \"userId\",\n                        \"in\": \"query\",\n                        \"description\": \"Identifier of the user. If set, only charges associated with this user will be returned.\",\n                        \"schema\": {\n                            \"type\": \"string\",\n                            \"format\": \"uuid\"\n                        }\n                    },\n                    {\n                        \"name\": \"farePassAllocationId\",\n                        \"in\": \"query\",\n                        \"description\": \"Identifier of the fare pass allocation. If set, only charges associated with this fare pass allocation will be returned.\",\n                        \"schema\": {\n                            \"type\": \"string\",\n                            \"format\": \"uuid\"\n                        }\n                    },\n                    {\n                        \"name\": \"externalIds\",\n                        \"in\": \"query\",\n                        \"style\": \"pipeDelimited\",\n                        \"explode\": false,\n                        \"schema\": {\n                            \"type\": \"array\",\n                            \"items\": {\n                                \"type\": \"string\"\n                            }\n                        }\n                    },\n                    {\n                        \"name\": \"groupChargeType\",\n                        \"in\": \"query\",\n                        \"description\": \"For group transaction charges, a parent charge represents the overall grouped charge, while a child charge refers to an individual charge within the group. If set to 'parent', only parent charges and non-grouped charges will be listed.\",\n                        \"schema\": {\n                            \"type\": \"string\",\n                            \"enum\": [\n                                \"parent\",\n                                \"child\"\n                            ]\n                        }\n                    },\n                    {\n                        \"name\": \"groupChargeId\",\n                        \"in\": \"query\",\n                        \"description\": \"Identifier of the group charge. If set, only charges associated with the group charge will be returned\",\n                        \"schema\": {\n                            \"type\": \"string\",\n                            \"format\": \"uuid\"\n                        }\n                    }\n                ],\n                \"responses\": {\n                    \"200\": {\n                        \"description\": \"\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"type\": \"object\",\n                   