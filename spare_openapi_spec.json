            }\n                            }\n                        }\n                    }\n                },\n                \"security\": [\n                    {\n                        \"Authorization\": []\n                    }\n                ]\n            }\n        },\n        \"/charges/{id}\": {\n            \"parameters\": [\n                {\n                    \"name\": \"id\",\n                    \"in\": \"path\",\n                    \"required\": true,\n                    \"schema\": {\n                        \"type\": \"string\",\n                        \"format\": \"uuid\"\n                    }\n                }\n            ],\n            \"get\": {\n                \"operationId\": \"GET-charge\",\n                \"summary\": \"Retrieve a charge\",\n                \"tags\": [\n                    \"Charges\"\n                ],\n                \"responses\": {\n                    \"200\": {\n                        \"description\": \"\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Charge\"\n                                }\n                            }\n                        }\n                    },\n                    \"default\": {\n                        \"description\": \"Error\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"$ref\": \"#/components/schemas/Error\"\n                                }\n                            }\n                        }\n                    }\n                },\n                \"security\": [\n                    {\n                        \"Authorization\": []\n                    }\n                ]\n            }\n        },\n        \"/charges/{id}/refund\": {\n            \"pa