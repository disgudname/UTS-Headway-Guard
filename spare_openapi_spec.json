ject\",\n                \"additionalProperties\": false,\n                \"properties\": {\n                    \"type\": {\n                        \"$ref\": \"#/components/schemas/AccessibilityFeature\"\n                    },\n                    \"count\": {\n                        \"type\": \"number\",\n                        \"default\": \"\",\n                        \"description\": \"Number of this accessibility feature that are required for this request\",\n                        \"minimum\": 1\n                    }\n                },\n                \"required\": [\n                    \"type\",\n                    \"count\"\n                ]\n            },\n            \"AccessibilityFeature\": {\n                \"title\": \"AccessibilityFeature\",\n                \"description\": \"Physical accommodation required by a Request. Requests specifying Accessibility Features will only be matched to Vehicles designated as offering those features.\",\n                \"type\": \"string\",\n                \"enum\": [\n                    \"wheelchair\",\n                    \"foldingWheelchair\",\n                    \"poweredWheelchair\",\n                    \"oversizedWheelchair\",\n                    \"scooter\",\n                    \"oversizedScooter\",\n                    \"walker\",\n                    \"oversizedWalker\",\n                    \"onlyCarWalker\",\n                    \"onlyCarRider\",\n                    \"extraSpaceAmbulant\",\n                    \"actualDoorToDoor\",\n                    \"lift\",\n                    \"oversizedItem\",\n                    \"stroller\",\n                    \"childSeatBaby\",\n                    \"childSeatYoung\",\n                    \"bike\",\n                    \"whiteCane\",\n                    \"serviceAnimal\",\n                    \"oxygenTank\",\n                    \"stretcher\"\n                ]\n            },\n            \"TransitMode\": {\n                \"title\"