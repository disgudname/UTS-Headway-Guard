"{\n    \"openapi\": \"3.0.3\",\n    \"info\": {\n        \"version\": \"v1\",\n        \"title\": \"Spare Open API\",\n        \"description\": \"API for Spare Platform.\"\n    },\n    \"servers\": [\n        {\n            \"url\": \"https://api.sparelabs.com/v1\",\n            \"description\": \"Production Canada\"\n        },\n        {\n            \"url\": \"https://api.us.sparelabs.com/v1\",\n            \"description\": \"Production US\"\n        },\n        {\n            \"url\": \"https://api.us2.sparelabs.com/v1\",\n            \"description\": \"Production US2\"\n        },\n        {\n            \"url\": \"https://api.jp.sparelabs.com/v1\",\n            \"description\": \"Production JP\"\n        },\n        {\n            \"url\": \"https://api.eu.sparelabs.com/v1\",\n            \"description\": \"Production EU\"\n        },\n        {\n            \"url\": \"https://api.uat.sparelabs.com/v1\",\n            \"description\": \"Production UAT\"\n        },\n        {\n            \"url\": \"https://api.staging.sparelabs.com/v1\",\n            \"description\": \"Staging Canada\"\n        },\n        {\n            \"url\": \"https://api.staging.us.sparelabs.com/v1\",\n            \"description\": \"Staging US\"\n        },\n        {\n            \"url\": \"http://localhost:3000/v1\",\n            \"description\": \"Local Development\"\n        }\n    ],\n    \"paths\": {\n        \"/announcements\": {\n            \"get\": {\n                \"operationId\": \"LIST-announcements\",\n                \"summary\": \"List all announcements\",\n                \"tags\": [\n                    \"Announcements\"\n                ],\n                \"parameters\": [\n                    {\n                        \"$ref\": \"#/components/parameters/LimitHigh\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/Skip\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/FromCreatedAt\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/ToCreatedAt\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/OrderBy\"\n                    },\n                    {\n                        \"$ref\": \"#/components/parameters/OrderDirection\"\n                    },\n                    {\n                        \"name\": \"status\",\n                        \"in\": \"query\",\n                        \"explode\": false,\n                        \"style\": \"pipeDelimited\",\n                        \"schema\": {\n                            \"type\": \"array\",\n                            \"items\": {\n                                \"$ref\": \"#/components/schemas/AnnouncementStatus\"\n                            }\n                        }\n                    }\n                ],\n                \"responses\": {\n                    \"200\": {\n                        \"description\": \"\",\n                        \"content\": {\n                            \"application/json\": {\n                                \"schema\": {\n                                    \"type\": \"object\",\n                                    \"properties\": {\n                                        \"total\": {\n                                            \"type\": \"integer\",\n                                            \"description\": \"Total number of entries\"\n                                        },\n                                        \"limit\": {\n                                            \"type\": \"integer\",\n                                            \"description\": \"Limit which was supplied by the body. Used for pagination\"\n                                        },\n                                        \"skip\": {\n                                            \"type\": \"integer\",\n    